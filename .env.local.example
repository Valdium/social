# Public chain RPC the frontend reads from.
NEXT_PUBLIC_VALDIUM_RPC=https://testnet.valdium.xyz

# Indexer service (HTTP for /activities, WS for live toasts).
# In dev, the local indexer runs on :3001.
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001 
NEXT_PUBLIC_INDEXER_WS=ws://localhost:3001

# Reown AppKit project (shared with valdium.xyz so connection state can
# carry over). Override only if you have your own.
NEXT_PUBLIC_REOWN_PROJECT_ID=c979efd3dfde8a921dd072943567edc1

# Wallet-bot API for the 6-digit code connect flow.
NEXT_PUBLIC_WALLET_BOT_URL=https://wallet.valdium.xyz
